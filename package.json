{
    "name": "jikanban",
    "module": "src/index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "prepare": "lefthook install",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "check": "bun lint:fix && bun check:types && bun check:dead-code && bun check:dupes && bun check:health",
        "check:types": "tsc --noEmit",
        "check:dead-code": "bun run fallow dead-code",
        "check:dupes": "bun run fallow dupes",
        "check:health": "bun run fallow health",
        "check:audit": "bun run fallow audit"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.0",
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@types/bun": "^1.3.14",
        "fallow": "^2.100.0",
        "lefthook": "^2.1.9",
        "typescript": "^6.0.3"
    },
    "peerDependencies": {}
}
